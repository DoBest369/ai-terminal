<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="using:TermindWindows"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="760"
        x:Class="TermindWindows.MainWindow"
        Title="Termind" Width="1200" Height="760"
        Background="#0D0E1A"
        ExtendClientAreaToDecorationsHint="True">
    <!-- Termind 智能 SSH 服务器运维工作台（Windows · Avalonia，三栏工作台对齐 apple/android）-->
    <!-- 扩展客户区到标题栏：消除系统浅色标题栏与深色内容割裂，整窗统一深色；顶部留 30px 给红绿灯按钮 -->
    <Grid ColumnDefinitions="280,*,340" Margin="0,30,0,0">

        <!-- ① 侧边栏：品牌+工具栏 + 搜索 + 连接列表 -->
        <Border Grid.Column="0" Background="#16182A">
            <StackPanel>
                <!-- 品牌 + 工具栏（新建连接 / 设置） -->
                <Grid ColumnDefinitions="*,Auto,Auto,Auto" Margin="16,16,10,12">
                    <TextBlock Grid.Column="0" Text="Termind" FontSize="20" FontWeight="Bold"
                               Foreground="#FFFFFF" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Background="Transparent" BorderThickness="0" Padding="6"
                            ToolTip.Tip="SFTP 文件" Click="OnSftpOpen">
                        <PathIcon Width="16" Height="16" Foreground="#8B92A8"
                                  Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z"/>
                        <!-- SFTP 文件浏览 Flyout（真实 SSH ls 取选中连接目录，对照 apple/android/linux） -->
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedLeft">
                                <StackPanel Width="320" Spacing="2">
                                    <TextBlock Text="SFTP 文件" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="SftpPath" Text="~" Foreground="#8B92A8" FontFamily="{StaticResource MonoFont}" FontSize="12" Margin="0,0,0,6"/>
                                    <!-- 新建目录（apple sftpMakeDirectory）+ 上传（apple sftpUpload）-->
                                    <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,4">
                                        <Border Grid.Column="0" Background="#0D0E1A" CornerRadius="6" Margin="0,0,6,0">
                                            <TextBox x:Name="NewDirName" PlaceholderText="新建目录名…" Background="Transparent" BorderThickness="0" Foreground="#C9D1D9" FontSize="12" FontFamily="{StaticResource MonoFont}" Padding="10,5"/>
                                        </Border>
                                        <Button Grid.Column="1" Click="OnMkdir" Background="#1A3FB950" BorderThickness="0" CornerRadius="6" Padding="10,5" Content="新建" Foreground="#3FB950" FontSize="12" Margin="0,0,6,0"/>
                                        <Button Grid.Column="2" Click="OnSftpUpload" Background="#1A60A5FA" BorderThickness="0" CornerRadius="6" Padding="10,5" Content="上传" Foreground="#60A5FA" FontSize="12" ToolTip.Tip="上传本地文件到当前目录"/>
                                    </Grid>
                                    <Border Height="1" Background="#2A2D3E" Margin="0,0,0,4"/>
                                    <StackPanel x:Name="SftpList" Spacing="2"/>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                    <Button Grid.Column="2" Background="Transparent" BorderThickness="0" Padding="6"
                            ToolTip.Tip="新建连接">
                        <PathIcon Width="16" Height="16" Foreground="#FF4B6E"
                                  Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z"/>
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedLeft">
                                <StackPanel Width="240" Spacing="8">
                                    <TextBlock Text="新建连接" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold"/>
                                    <Border Background="#0D0E1A" CornerRadius="6"><TextBox x:Name="NewConnName" PlaceholderText="名称（如 生产服务器）" Background="Transparent" BorderThickness="0" Foreground="#C9D1D9" FontSize="12" Padding="10,7"/></Border>
                                    <Border Background="#0D0E1A" CornerRadius="6"><TextBox x:Name="NewConnHost" PlaceholderText="主机 IP / 域名" Background="Transparent" BorderThickness="0" Foreground="#C9D1D9" FontSize="12" FontFamily="{StaticResource MonoFont}" Padding="10,7"/></Border>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Border Grid.Column="0" Background="#0D0E1A" CornerRadius="6" Margin="0,0,6,0"><TextBox x:Name="NewConnUser" PlaceholderText="用户（root）" Background="Transparent" BorderThickness="0" Foreground="#C9D1D9" FontSize="12" FontFamily="{StaticResource MonoFont}" Padding="10,7"/></Border>
                                        <Border Grid.Column="1" Background="#0D0E1A" CornerRadius="6" Width="64"><TextBox x:Name="NewConnPort" Text="22" Background="Transparent" BorderThickness="0" Foreground="#C9D1D9" FontSize="12" FontFamily="{StaticResource MonoFont}" Padding="10,7"/></Border>
                                    </Grid>
                                    <Button Click="OnAddConn" Background="#FF4B6E" Foreground="#FFFFFF" BorderThickness="0" CornerRadius="6" Padding="10,6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Content="添加" FontSize="12" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                    <Button Grid.Column="3" Background="Transparent" BorderThickness="0" Padding="6"
                            ToolTip.Tip="设置">
                        <PathIcon Width="16" Height="16" Foreground="#8B92A8"
                                  Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"/>
                        <!-- 设置面板 Flyout（对照 apple SettingsView） -->
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedLeft">
                                <StackPanel Width="280" Spacing="12">
                                    <TextBlock Text="设置" Foreground="#FFFFFF" FontSize="15" FontWeight="Bold"/>
                                    <!-- 配色主题 -->
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="配色主题" Foreground="#8B92A8" FontSize="11" FontWeight="SemiBold"/>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Border Background="#1A3B82F6" CornerRadius="6" Padding="10,5"><TextBlock Text="午夜" Foreground="#3B82F6" FontSize="12"/></Border>
                                            <Border Background="#22000000" CornerRadius="6" Padding="10,5"><TextBlock Text="Dracula" Foreground="#8B92A8" FontSize="12"/></Border>
                                            <Border Background="#22000000" CornerRadius="6" Padding="10,5"><TextBlock Text="Nord" Foreground="#8B92A8" FontSize="12"/></Border>
                                        </StackPanel>
                                    </StackPanel>
                                    <!-- AI 服务商 -->
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="AI 服务商" Foreground="#8B92A8" FontSize="11" FontWeight="SemiBold"/>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Border Background="#1A3B82F6" CornerRadius="6" Padding="10,5"><TextBlock Text="Anthropic Claude" Foreground="#3B82F6" FontSize="12"/></Border>
                                            <Border Background="#22000000" CornerRadius="6" Padding="10,5"><TextBlock Text="OpenAI" Foreground="#8B92A8" FontSize="12"/></Border>
                                        </StackPanel>
                                    </StackPanel>
                                    <!-- API Key -->
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="API Key" Foreground="#8B92A8" FontSize="11" FontWeight="SemiBold"/>
                                        <Border Background="#0D0E1A" CornerRadius="6">
                                            <TextBox x:Name="ApiKeyBox" PlaceholderText="留空则用 TERMIND_AI_KEY 环境变量" PasswordChar="•" Background="Transparent" BorderThickness="0" Foreground="#C9D1D9" FontSize="12" Padding="10,7"/>
                                        </Border>
                                    </StackPanel>
                                    <!-- 模型 -->
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="模型" Foreground="#8B92A8" FontSize="11" FontWeight="SemiBold"/>
                                        <TextBlock Text="claude-opus-4-8" Foreground="#C9D1D9" FontSize="12" FontFamily="{StaticResource MonoFont}"/>
                                    </StackPanel>
                                    <!-- API 地址（Base URL，对齐 apple/android；OpenAI 兼容/代理/自托管） -->
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="API 地址" Foreground="#8B92A8" FontSize="11" FontWeight="SemiBold"/>
                                        <Border Background="#0D0E1A" CornerRadius="6">
                                            <TextBox x:Name="BaseUrlBox" PlaceholderText="留空用默认 nexcores（Anthropic 兼容）" Background="Transparent" BorderThickness="0" Foreground="#C9D1D9" FontSize="11" FontFamily="{StaticResource MonoFont}" Padding="10,7"/>
                                        </Border>
                                    </StackPanel>
                                    <!-- AI 系统提示词（可自定义，对齐 apple/android/linux） -->
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="AI 系统提示词" Foreground="#8B92A8" FontSize="11" FontWeight="SemiBold"/>
                                        <Border Background="#0D0E1A" CornerRadius="6">
                                            <TextBox Text="你是 Termind 的 SSH 运维助手。结合服务器环境给出安全、可直接执行的运维建议；危险操作必须警示并建议先备份。回答精炼、用中文，命令用代码块。" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="64" MaxHeight="100" Background="Transparent" BorderThickness="0" Foreground="#C9D1D9" FontSize="11" Padding="10,7"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </Grid>
                <!-- 搜索框（可输入） -->
                <Border Background="#0D0E1A" CornerRadius="8" Margin="10,0,10,10">
                    <TextBox PlaceholderText="🔍  搜索连接" Background="Transparent" BorderThickness="0"
                             Foreground="#C9D1D9" FontSize="13" Padding="10,8" CaretBrush="#FF4B6E"/>
                </Border>
                <TextBlock Text="SSH 连接 (3)" FontSize="11" FontWeight="SemiBold"
                           Foreground="#6B7280" Margin="16,6,16,6"/>
                <!-- 连接列表：ListBox 自带选中高亮 / hover / 键盘上下导航（真正可交互） -->
                <ListBox x:Name="ConnList" Background="Transparent" BorderThickness="0" Margin="4,0" SelectionChanged="OnConnSelected">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="local:ConnItem">
                            <StackPanel>
                                <!-- 分组标题（组内第一个显示，对照 apple/android/linux 分组） -->
                                <TextBlock Text="{Binding GroupName}" IsVisible="{Binding ShowHeader}"
                                           Foreground="#6B7280" FontSize="11" FontWeight="SemiBold" Margin="2,6,0,4"/>
                                <Grid ColumnDefinitions="3,Auto,*,Auto" Margin="0,3">
                                    <!-- 右键菜单：编辑/删除连接（连接管理 CRUD） -->
                                    <Grid.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuItem Header="编辑连接" Click="OnEditConn"/>
                                            <MenuItem Header="删除连接" Click="OnDeleteConn"/>
                                        </MenuFlyout>
                                    </Grid.ContextFlyout>
                                    <Border Grid.Column="0" Background="{Binding Bar}" CornerRadius="2" Width="3" Height="30" Margin="0,0,8,0"/>
                                    <Ellipse Grid.Column="1" Width="8" Height="8" Fill="{Binding Dot}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{Binding Name}" Foreground="#FFFFFF" FontSize="13" FontWeight="Medium"/>
                                        <TextBlock Text="{Binding Addr}" Foreground="#8B92A8" FontSize="11"/>
                                        <TextBlock Text="{Binding Note}" IsVisible="{Binding HasNote}" Foreground="#6B7280" FontSize="10"/>
                                        <TextBlock Text="{Binding LastUsed}" IsVisible="{Binding HasLastUsed}" Foreground="#5A6270" FontSize="10"/>
                                    </StackPanel>
                                    <!-- 可达指示（对照 apple/android/linux wifi） -->
                                    <TextBlock Grid.Column="3" Text="{Binding Reach}" Foreground="{Binding ReachColor}" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Margin="6,0"/>
                                </Grid>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- ② 终端区：状态条 + 输出 + 快捷命令 + 输入 -->
        <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto,Auto" Background="#0D0E1A">
            <!-- 状态条（CPU/内存 mini 进度条，绿/橙/红三档，对齐 apple/android/linux） -->
            <Border Grid.Row="0" Background="#16182A" Padding="14,8">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16">
                    <TextBlock x:Name="StatusDot" Text="● 已连接" Foreground="#3FB950" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusHost" Text="主机 db.internal.net" Foreground="#C9D1D9" FontSize="12" VerticalAlignment="Center"/>
                    <!-- CPU 47% -->
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Text="CPU 47%" Foreground="#C9D1D9" FontSize="12" VerticalAlignment="Center"/>
                        <Border Width="54" Height="4" Background="#1AFFFFFF" CornerRadius="2" VerticalAlignment="Center">
                            <Border Width="25" Height="4" Background="#3FB950" CornerRadius="2" HorizontalAlignment="Left"/>
                        </Border>
                    </StackPanel>
                    <!-- 内存 56% -->
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Text="内存 56%" Foreground="#C9D1D9" FontSize="12" VerticalAlignment="Center"/>
                        <Border Width="54" Height="4" Background="#1AFFFFFF" CornerRadius="2" VerticalAlignment="Center">
                            <Border Width="30" Height="4" Background="#3FB950" CornerRadius="2" HorizontalAlignment="Left"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="负载 0.82" Foreground="#8B92A8" FontSize="12" VerticalAlignment="Center"/>
                    <!-- 关键服务状态点（对照 apple/android/linux Z6） -->
                    <Border Width="1" Height="16" Background="#2A2D3E" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                        <TextBlock Text="●" Foreground="#3FB950" FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock Text="nginx" Foreground="#C9D1D9" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                        <TextBlock Text="●" Foreground="#3FB950" FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock Text="docker" Foreground="#C9D1D9" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                        <TextBlock Text="●" Foreground="#6B7280" FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock Text="redis" Foreground="#8B92A8" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
                <!-- 终端字号调整（U4 用户要求：字号可调）-->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                    <Button Click="OnFontSmaller" Background="#22FFFFFF" BorderThickness="0" CornerRadius="4" Padding="7,2" Content="A-" Foreground="#8B92A8" FontSize="11" ToolTip.Tip="缩小终端字号"/>
                    <Button Click="OnFontLarger" Background="#22FFFFFF" BorderThickness="0" CornerRadius="4" Padding="7,2" Content="A+" Foreground="#8B92A8" FontSize="11" ToolTip.Tip="放大终端字号"/>
                </StackPanel>
              </Grid>
            </Border>
            <!-- 终端输出（可滚动） -->
            <Border Grid.Row="1" Background="#0A0B14" Margin="10">
                <ScrollViewer x:Name="TermScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <StackPanel x:Name="TermOutput" Margin="14">
                        <TextBlock Text="Last login: Sun Jun 22 19:00 on ttys001" Foreground="#8B92A8" FontFamily="{StaticResource MonoFont}" FontSize="12.5"/>
                        <TextBlock Text="root@prod-01:~$ ls -la" Foreground="#C9D1D9" FontFamily="{StaticResource MonoFont}" FontSize="12.5" Margin="0,4,0,0"/>
                        <TextBlock Text="total 32" Foreground="#C9D1D9" FontFamily="{StaticResource MonoFont}" FontSize="12.5"/>
                        <TextBlock Text="drwxr-xr-x  6 root root 4096 Jun 22 18:00 ." Foreground="#C9D1D9" FontFamily="{StaticResource MonoFont}" FontSize="12.5"/>
                        <TextBlock Text="drwxr-xr-x 18 root root 4096 Jun 10 09:12 .." Foreground="#C9D1D9" FontFamily="{StaticResource MonoFont}" FontSize="12.5"/>
                        <TextBlock Text="-rw-r--r--  1 root root  220 Jun 10 09:12 .bashrc" Foreground="#C9D1D9" FontFamily="{StaticResource MonoFont}" FontSize="12.5"/>
                        <TextBlock Text="-rwxr-xr-x  1 root root 1024 Jun 22 17:30 deploy.sh" Foreground="#3FB950" FontFamily="{StaticResource MonoFont}" FontSize="12.5"/>
                        <TextBlock Text="drwxr-xr-x  4 root root 4096 Jun 22 18:00 projects" Foreground="#FF4B6E" FontFamily="{StaticResource MonoFont}" FontSize="12.5"/>
                        <TextBlock Text="root@prod-01:~$ systemctl status nginx" Foreground="#C9D1D9" FontFamily="{StaticResource MonoFont}" FontSize="12.5" Margin="0,4,0,0"/>
                        <TextBlock Text="● nginx.service - A high performance web server" Foreground="#3FB950" FontFamily="{StaticResource MonoFont}" FontSize="12.5"/>
                        <TextBlock Text="   Active: active (running) since Mon 2026-06-22" Foreground="#C9D1D9" FontFamily="{StaticResource MonoFont}" FontSize="12.5"/>
                        <TextBlock x:Name="TermCursor" Text="root@prod-01:~$ █" Foreground="#C9D1D9" FontFamily="{StaticResource MonoFont}" FontSize="12.5" Margin="0,4,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
            <!-- 快捷命令 chip 横栏（点击填入，对照 apple/android） -->
            <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="10,0,10,6">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button Background="#1AFF4B6E" BorderThickness="0" CornerRadius="14" Padding="10,5" Click="OnQuickCmd"
                            Content="ls -la" Foreground="#FF4B6E" FontFamily="{StaticResource MonoFont}" FontSize="11"/>
                    <Button Background="#1AFF4B6E" BorderThickness="0" CornerRadius="14" Padding="10,5" Click="OnQuickCmd"
                            Content="df -h" Foreground="#FF4B6E" FontFamily="{StaticResource MonoFont}" FontSize="11"/>
                    <Button Background="#1AFF4B6E" BorderThickness="0" CornerRadius="14" Padding="10,5" Click="OnQuickCmd"
                            Content="free -h" Foreground="#FF4B6E" FontFamily="{StaticResource MonoFont}" FontSize="11"/>
                    <Button Background="#1AFF4B6E" BorderThickness="0" CornerRadius="14" Padding="10,5" Click="OnQuickCmd"
                            Content="ps aux --sort=-%cpu | head" Foreground="#FF4B6E" FontFamily="{StaticResource MonoFont}" FontSize="11"/>
                    <Button Background="#1AFF4B6E" BorderThickness="0" CornerRadius="14" Padding="10,5" Click="OnQuickCmd"
                            Content="ss -tlnp" Foreground="#FF4B6E" FontFamily="{StaticResource MonoFont}" FontSize="11"/>
                    <Button Background="#1AFF4B6E" BorderThickness="0" CornerRadius="14" Padding="10,5" Click="OnQuickCmd"
                            Content="uptime" Foreground="#FF4B6E" FontFamily="{StaticResource MonoFont}" FontSize="11"/>
                    <Button Background="#1AFF4B6E" BorderThickness="0" CornerRadius="14" Padding="10,5" Click="OnQuickCmd"
                            Content="top" Foreground="#FF4B6E" FontFamily="{StaticResource MonoFont}" FontSize="11"/>
                    <Button Background="#1AF59E0B" BorderThickness="0" CornerRadius="14" Padding="10,5" Click="OnQuickCmd"
                            Content="journalctl -xe -n 50" Foreground="#F59E0B" FontFamily="{StaticResource MonoFont}" FontSize="11"/>
                    <Button Background="#1AF59E0B" BorderThickness="0" CornerRadius="14" Padding="10,5" Click="OnQuickCmd"
                            Content="systemctl status nginx" Foreground="#F59E0B" FontFamily="{StaticResource MonoFont}" FontSize="11"/>
                </StackPanel>
            </ScrollViewer>
            <!-- 命令输入（可真实输入）+ 批量群发（护城河：多连接群发命令） -->
            <Border Grid.Row="3" Background="#16182A" CornerRadius="8" Margin="10,0,10,10">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBox x:Name="CmdInput" Grid.Column="0" PlaceholderText="输入命令…" Background="Transparent" BorderThickness="0"
                             Foreground="#C9D1D9" FontFamily="{StaticResource MonoFont}" FontSize="13"
                             Padding="12,9" CaretBrush="#FF4B6E" KeyDown="OnCmdKeyDown"/>
                    <Button Grid.Column="1" Click="OnBatchExec" Background="Transparent" BorderThickness="0" Padding="8"
                            VerticalAlignment="Center" ToolTip.Tip="批量群发：对所有连接执行此命令">
                        <PathIcon Width="15" Height="15" Foreground="#F59E0B"
                                  Data="M16,13C15.71,13 15.38,13 15.03,13.05C16.19,13.89 17,15 17,16.5V19H23V16.5C23,14.17 18.33,13 16,13M8,13C5.67,13 1,14.17 1,16.5V19H15V16.5C15,14.17 10.33,13 8,13M8,11A3,3 0 0,0 11,8A3,3 0 0,0 8,5A3,3 0 0,0 5,8A3,3 0 0,0 8,11M16,11A3,3 0 0,0 19,8A3,3 0 0,0 16,5A3,3 0 0,0 13,8A3,3 0 0,0 16,11Z"/>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- ③ AI 面板：对话 + 快捷追问 + 输入 -->
        <Grid Grid.Column="2" RowDefinitions="Auto,*,Auto,Auto" Background="#10121F">
            <Border Grid.Row="0" Padding="14,10">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <TextBlock Grid.Column="0" Text="✦ AI 助手" Foreground="#FF4B6E" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Click="OnExportChat" Background="Transparent" BorderThickness="0" Padding="4"
                                ToolTip.Tip="导出对话为 Markdown">
                            <PathIcon Width="14" Height="14" Foreground="#8B92A8"
                                      Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,8L14,2M12,19L8,15H10.5V12H13.5V15H16L12,19M13,9V3.5L18.5,9H13Z"/>
                        </Button>
                        <Button Grid.Column="2" Click="OnClearChat" Background="Transparent" BorderThickness="0" Padding="4"
                                ToolTip.Tip="清空对话（新建会话）">
                            <PathIcon Width="14" Height="14" Foreground="#8B92A8"
                                      Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"/>
                        </Button>
                    </Grid>
                    <!-- AI 三模式切换器（Chat/Agent/Auto，安全梯度，对齐用户设计）+ AI 字号 -->
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border Grid.Column="0" Background="#16182A" CornerRadius="8" Padding="3" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="2">
                                <Button x:Name="ModeChat" Click="OnModeChat" Background="#FF4B6E" BorderThickness="0" CornerRadius="6" Padding="10,4"
                                        Content="聊天" Foreground="#FFFFFF" FontSize="11" ToolTip.Tip="纯聊天：AI 只建议，不碰终端"/>
                                <Button x:Name="ModeAgent" Click="OnModeAgent" Background="Transparent" BorderThickness="0" CornerRadius="6" Padding="10,4"
                                        Content="代理" Foreground="#8B92A8" FontSize="11" ToolTip.Tip="代理：AI 生成命令，每条需你确认放行"/>
                                <Button x:Name="ModeAuto" Click="OnModeAuto" Background="Transparent" BorderThickness="0" CornerRadius="6" Padding="10,4"
                                        Content="全自动" Foreground="#8B92A8" FontSize="11" ToolTip.Tip="全自动：AI 自主读输出→决策→执行→闭环（高危仍需确认）"/>
                            </StackPanel>
                        </Border>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                            <Button Click="OnAiFontSmaller" Background="#22FFFFFF" BorderThickness="0" CornerRadius="4" Padding="6,2" Content="A-" Foreground="#8B92A8" FontSize="10" ToolTip.Tip="缩小 AI 字号"/>
                            <Button Click="OnAiFontLarger" Background="#22FFFFFF" BorderThickness="0" CornerRadius="4" Padding="6,2" Content="A+" Foreground="#8B92A8" FontSize="10" ToolTip.Tip="放大 AI 字号"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
            <ScrollViewer x:Name="AiScroll" Grid.Row="1" Margin="12,0">
                <StackPanel x:Name="AiMessages" Spacing="8">
                    <!-- 第一轮对话 -->
                    <TextBlock Text="你" Foreground="#8B92A8" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right"/>
                    <Border Background="#3B82F6" CornerRadius="10" Padding="12,9" HorizontalAlignment="Right" MaxWidth="260">
                        <TextBlock Text="这台机器装了什么服务？" Foreground="#FFFFFF" FontSize="13" TextWrapping="Wrap"/>
                    </Border>
                    <TextBlock Foreground="#8B92A8" FontSize="10" FontWeight="Bold" HorizontalAlignment="Left">
                        <Run Text="✦" Foreground="#FF4B6E"/><Run Text=" AI"/>
                    </TextBlock>
                    <Border Background="#0D0E1A" CornerRadius="10" Padding="12,9" HorizontalAlignment="Left" MaxWidth="290">
                        <TextBlock Text="检测到 nginx(运行)、docker(运行)、mysql(运行)、redis(未运行)。需要我帮你启动 redis 吗？" Foreground="#C9D1D9" FontSize="13" TextWrapping="Wrap"/>
                    </Border>
                    <!-- 第二轮对话：角色标签 + 气泡（对照 apple/android/linux） -->
                    <TextBlock Text="你" Foreground="#8B92A8" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right"/>
                    <Border Background="#3B82F6" CornerRadius="10" Padding="12,9" HorizontalAlignment="Right" MaxWidth="260">
                        <TextBlock Text="怎么查看 Nginx 错误日志？" Foreground="#FFFFFF" FontSize="13" TextWrapping="Wrap"/>
                    </Border>
                    <!-- AI 消息：角色标签 + 气泡 + 代码块 -->
                    <TextBlock Foreground="#8B92A8" FontSize="10" FontWeight="Bold" HorizontalAlignment="Left">
                        <Run Text="✦" Foreground="#FF4B6E"/><Run Text=" AI"/>
                    </TextBlock>
                    <Border Background="#0D0E1A" CornerRadius="10" Padding="12,9" HorizontalAlignment="Left" MaxWidth="290">
                        <StackPanel Spacing="6">
                            <TextBlock Text="用下面的命令查看最近的 Nginx 错误日志：" Foreground="#C9D1D9" FontSize="13" TextWrapping="Wrap"/>
                            <Border Background="#000000" CornerRadius="6" Padding="8">
                                <TextBlock Text="tail -n 50 /var/log/nginx/error.log" Foreground="#3FB950" FontFamily="{StaticResource MonoFont}" FontSize="12" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
            <!-- 运维快捷入口（对照 apple 护城河 Z1命令解释/Z2报错分析/Z3健康巡检）+ 快捷追问 -->
            <StackPanel Grid.Row="2" Spacing="6" Margin="12,8">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button Background="#1AFF4B6E" BorderThickness="0" CornerRadius="14" Padding="10,5" Click="OnOpsQuick"
                            Tag="explain" Content="解释命令" Foreground="#FF4B6E" FontSize="11"/>
                    <Button Background="#1AFF4B6E" BorderThickness="0" CornerRadius="14" Padding="10,5" Click="OnOpsQuick"
                            Tag="error" Content="分析报错" Foreground="#FF4B6E" FontSize="11"/>
                    <Button Background="#1AFF4B6E" BorderThickness="0" CornerRadius="14" Padding="10,5" Click="OnOpsQuick"
                            Tag="health" Content="健康巡检" Foreground="#FF4B6E" FontSize="11"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button Background="#1A3B82F6" BorderThickness="0" CornerRadius="14" Padding="10,5" Click="OnQuickAsk"
                            Content="如何排查？" Foreground="#3B82F6" FontSize="11"/>
                    <Button Background="#1A3B82F6" BorderThickness="0" CornerRadius="14" Padding="10,5" Click="OnQuickAsk"
                            Content="给我具体命令" Foreground="#3B82F6" FontSize="11"/>
                    <Button Background="#1A3FB950" BorderThickness="0" CornerRadius="14" Padding="10,5" Click="OnQuickAsk"
                            Content="有什么风险？" Foreground="#3FB950" FontSize="11"/>
                </StackPanel>
            </StackPanel>
            <!-- AI 输入（可真实输入） -->
            <Border Grid.Row="3" Background="#16182A" CornerRadius="8" Margin="12,0,12,12" Padding="4,2">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBox x:Name="AiInput" Grid.Column="0" PlaceholderText="输入指令…" Background="Transparent" BorderThickness="0"
                             Foreground="#C9D1D9" FontSize="13" VerticalAlignment="Center" Padding="8,7" CaretBrush="#FF4B6E" KeyDown="OnAiKeyDown"/>
                    <Button Grid.Column="1" Background="#FF4B6E" CornerRadius="14" Width="28" Height="28" Padding="0"
                            VerticalAlignment="Center" Margin="4,0" Click="OnAiSend">
                        <TextBlock Text="↑" Foreground="#FFFFFF" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
