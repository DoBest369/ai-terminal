<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="using:TermindWindows"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="760"
        x:Class="TermindWindows.MainWindow"
        Title="Termind" Width="1200" Height="760"
        Background="#0D0E1A">
    <!-- Termind 智能 SSH 服务器运维工作台（Windows · Avalonia，三栏工作台对齐 apple/android）-->
    <Grid ColumnDefinitions="280,*,340">

        <!-- ① 侧边栏：品牌+工具栏 + 搜索 + 连接列表 -->
        <Border Grid.Column="0" Background="#16182A">
            <StackPanel>
                <!-- 品牌 + 工具栏（新建连接 / 设置） -->
                <Grid ColumnDefinitions="*,Auto,Auto" Margin="16,16,10,12">
                    <TextBlock Grid.Column="0" Text="Termind" FontSize="20" FontWeight="Bold"
                               Foreground="#FFFFFF" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Background="Transparent" BorderThickness="0" Padding="6"
                            ToolTip.Tip="新建连接">
                        <TextBlock Text="＋" Foreground="#FF4B6E" FontSize="18"/>
                    </Button>
                    <Button Grid.Column="2" Background="Transparent" BorderThickness="0" Padding="6"
                            ToolTip.Tip="设置">
                        <TextBlock Text="⚙" Foreground="#8B92A8" FontSize="16"/>
                    </Button>
                </Grid>
                <!-- 搜索框（可输入） -->
                <Border Background="#0D0E1A" CornerRadius="8" Margin="10,0,10,10">
                    <TextBox PlaceholderText="🔍  搜索连接" Background="Transparent" BorderThickness="0"
                             Foreground="#C9D1D9" FontSize="13" Padding="10,8" CaretBrush="#FF4B6E"/>
                </Border>
                <TextBlock Text="SSH 连接 (3)" FontSize="11" FontWeight="SemiBold"
                           Foreground="#6B7280" Margin="16,6,16,6"/>
                <!-- 连接列表：ListBox 自带选中高亮 / hover / 键盘上下导航（真正可交互） -->
                <ListBox x:Name="ConnList" Background="Transparent" BorderThickness="0" Margin="4,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="local:ConnItem">
                            <StackPanel>
                                <!-- 分组标题（组内第一个显示，对照 apple/android/linux 分组） -->
                                <TextBlock Text="{Binding GroupName}" IsVisible="{Binding ShowHeader}"
                                           Foreground="#6B7280" FontSize="11" FontWeight="SemiBold" Margin="2,6,0,4"/>
                                <Grid ColumnDefinitions="3,Auto,*,Auto" Margin="0,3">
                                    <Border Grid.Column="0" Background="{Binding Bar}" CornerRadius="2" Width="3" Height="30" Margin="0,0,8,0"/>
                                    <Ellipse Grid.Column="1" Width="8" Height="8" Fill="{Binding Dot}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{Binding Name}" Foreground="#FFFFFF" FontSize="13" FontWeight="Medium"/>
                                        <TextBlock Text="{Binding Addr}" Foreground="#8B92A8" FontSize="11"/>
                                    </StackPanel>
                                    <!-- 可达指示（对照 apple/android/linux wifi） -->
                                    <TextBlock Grid.Column="3" Text="{Binding Reach}" Foreground="{Binding ReachColor}" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Margin="6,0"/>
                                </Grid>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- ② 终端区：状态条 + 输出 + 快捷命令 + 输入 -->
        <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto,Auto" Background="#0D0E1A">
            <!-- 状态条（CPU/内存 mini 进度条，绿/橙/红三档，对齐 apple/android/linux） -->
            <Border Grid.Row="0" Background="#16182A" Padding="14,8">
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <TextBlock Text="● 已连接" Foreground="#3FB950" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="主机 prod-01" Foreground="#C9D1D9" FontSize="12" VerticalAlignment="Center"/>
                    <!-- CPU 47% -->
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Text="CPU 47%" Foreground="#C9D1D9" FontSize="12" VerticalAlignment="Center"/>
                        <Border Width="54" Height="4" Background="#1AFFFFFF" CornerRadius="2" VerticalAlignment="Center">
                            <Border Width="25" Height="4" Background="#3FB950" CornerRadius="2" HorizontalAlignment="Left"/>
                        </Border>
                    </StackPanel>
                    <!-- 内存 56% -->
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Text="内存 56%" Foreground="#C9D1D9" FontSize="12" VerticalAlignment="Center"/>
                        <Border Width="54" Height="4" Background="#1AFFFFFF" CornerRadius="2" VerticalAlignment="Center">
                            <Border Width="30" Height="4" Background="#3FB950" CornerRadius="2" HorizontalAlignment="Left"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="负载 0.82" Foreground="#8B92A8" FontSize="12" VerticalAlignment="Center"/>
                    <!-- 关键服务状态点（对照 apple/android/linux Z6） -->
                    <Border Width="1" Height="16" Background="#2A2D3E" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                        <TextBlock Text="●" Foreground="#3FB950" FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock Text="nginx" Foreground="#C9D1D9" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                        <TextBlock Text="●" Foreground="#3FB950" FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock Text="docker" Foreground="#C9D1D9" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                        <TextBlock Text="●" Foreground="#6B7280" FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock Text="redis" Foreground="#8B92A8" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <!-- 终端输出（可滚动） -->
            <Border Grid.Row="1" Background="#0A0B14" Margin="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">
                        <TextBlock Text="Last login: Sun Jun 22 19:00 on ttys001" Foreground="#8B92A8" FontFamily="Consolas,monospace" FontSize="12.5"/>
                        <TextBlock Text="root@prod-01:~$ ls -la" Foreground="#C9D1D9" FontFamily="Consolas,monospace" FontSize="12.5" Margin="0,4,0,0"/>
                        <TextBlock Text="total 32" Foreground="#C9D1D9" FontFamily="Consolas,monospace" FontSize="12.5"/>
                        <TextBlock Text="drwxr-xr-x  6 root root 4096 Jun 22 18:00 ." Foreground="#C9D1D9" FontFamily="Consolas,monospace" FontSize="12.5"/>
                        <TextBlock Text="drwxr-xr-x 18 root root 4096 Jun 10 09:12 .." Foreground="#C9D1D9" FontFamily="Consolas,monospace" FontSize="12.5"/>
                        <TextBlock Text="-rw-r--r--  1 root root  220 Jun 10 09:12 .bashrc" Foreground="#C9D1D9" FontFamily="Consolas,monospace" FontSize="12.5"/>
                        <TextBlock Text="-rwxr-xr-x  1 root root 1024 Jun 22 17:30 deploy.sh" Foreground="#3FB950" FontFamily="Consolas,monospace" FontSize="12.5"/>
                        <TextBlock Text="drwxr-xr-x  4 root root 4096 Jun 22 18:00 projects" Foreground="#FF4B6E" FontFamily="Consolas,monospace" FontSize="12.5"/>
                        <TextBlock Text="root@prod-01:~$ systemctl status nginx" Foreground="#C9D1D9" FontFamily="Consolas,monospace" FontSize="12.5" Margin="0,4,0,0"/>
                        <TextBlock Text="● nginx.service - A high performance web server" Foreground="#3FB950" FontFamily="Consolas,monospace" FontSize="12.5"/>
                        <TextBlock Text="   Active: active (running) since Mon 2026-06-22" Foreground="#C9D1D9" FontFamily="Consolas,monospace" FontSize="12.5"/>
                        <TextBlock Text="root@prod-01:~$ █" Foreground="#C9D1D9" FontFamily="Consolas,monospace" FontSize="12.5" Margin="0,4,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
            <!-- 快捷命令 chip 横栏（点击填入，对照 apple/android） -->
            <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="10,0,10,6">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Border Background="#1AFF4B6E" CornerRadius="14" Padding="10,5"><TextBlock Text="ls -la" Foreground="#FF4B6E" FontFamily="Consolas,monospace" FontSize="11"/></Border>
                    <Border Background="#1AFF4B6E" CornerRadius="14" Padding="10,5"><TextBlock Text="df -h" Foreground="#FF4B6E" FontFamily="Consolas,monospace" FontSize="11"/></Border>
                    <Border Background="#1AFF4B6E" CornerRadius="14" Padding="10,5"><TextBlock Text="free -h" Foreground="#FF4B6E" FontFamily="Consolas,monospace" FontSize="11"/></Border>
                    <Border Background="#1AFF4B6E" CornerRadius="14" Padding="10,5"><TextBlock Text="top" Foreground="#FF4B6E" FontFamily="Consolas,monospace" FontSize="11"/></Border>
                    <Border Background="#1AF59E0B" CornerRadius="14" Padding="10,5"><TextBlock Text="systemctl status nginx" Foreground="#F59E0B" FontFamily="Consolas,monospace" FontSize="11"/></Border>
                </StackPanel>
            </ScrollViewer>
            <!-- 命令输入（可真实输入） -->
            <Border Grid.Row="3" Background="#16182A" CornerRadius="8" Margin="10,0,10,10">
                <TextBox PlaceholderText="输入命令…" Background="Transparent" BorderThickness="0"
                         Foreground="#C9D1D9" FontFamily="Consolas,monospace" FontSize="13"
                         Padding="12,9" CaretBrush="#FF4B6E"/>
            </Border>
        </Grid>

        <!-- ③ AI 面板：对话 + 快捷追问 + 输入 -->
        <Grid Grid.Column="2" RowDefinitions="Auto,*,Auto,Auto" Background="#10121F">
            <Border Grid.Row="0" Padding="14,12">
                <TextBlock Text="✦ AI 助手" Foreground="#FF4B6E" FontSize="14" FontWeight="Bold"/>
            </Border>
            <ScrollViewer Grid.Row="1" Margin="12,0">
                <StackPanel Spacing="8">
                    <!-- 第一轮对话 -->
                    <TextBlock Text="你" Foreground="#8B92A8" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right"/>
                    <Border Background="#3B82F6" CornerRadius="10" Padding="12,9" HorizontalAlignment="Right" MaxWidth="260">
                        <TextBlock Text="这台机器装了什么服务？" Foreground="#FFFFFF" FontSize="13" TextWrapping="Wrap"/>
                    </Border>
                    <TextBlock Foreground="#8B92A8" FontSize="10" FontWeight="Bold" HorizontalAlignment="Left">
                        <Run Text="✦" Foreground="#FF4B6E"/><Run Text=" AI"/>
                    </TextBlock>
                    <Border Background="#0D0E1A" CornerRadius="10" Padding="12,9" HorizontalAlignment="Left" MaxWidth="290">
                        <TextBlock Text="检测到 nginx(运行)、docker(运行)、mysql(运行)、redis(未运行)。需要我帮你启动 redis 吗？" Foreground="#C9D1D9" FontSize="13" TextWrapping="Wrap"/>
                    </Border>
                    <!-- 第二轮对话：角色标签 + 气泡（对照 apple/android/linux） -->
                    <TextBlock Text="你" Foreground="#8B92A8" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right"/>
                    <Border Background="#3B82F6" CornerRadius="10" Padding="12,9" HorizontalAlignment="Right" MaxWidth="260">
                        <TextBlock Text="怎么查看 Nginx 错误日志？" Foreground="#FFFFFF" FontSize="13" TextWrapping="Wrap"/>
                    </Border>
                    <!-- AI 消息：角色标签 + 气泡 + 代码块 -->
                    <TextBlock Foreground="#8B92A8" FontSize="10" FontWeight="Bold" HorizontalAlignment="Left">
                        <Run Text="✦" Foreground="#FF4B6E"/><Run Text=" AI"/>
                    </TextBlock>
                    <Border Background="#0D0E1A" CornerRadius="10" Padding="12,9" HorizontalAlignment="Left" MaxWidth="290">
                        <StackPanel Spacing="6">
                            <TextBlock Text="用下面的命令查看最近的 Nginx 错误日志：" Foreground="#C9D1D9" FontSize="13" TextWrapping="Wrap"/>
                            <Border Background="#000000" CornerRadius="6" Padding="8">
                                <TextBlock Text="tail -n 50 /var/log/nginx/error.log" Foreground="#3FB950" FontFamily="Consolas,monospace" FontSize="12" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
            <!-- 快捷追问 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="6" Margin="12,8">
                <Border Background="#1A3B82F6" CornerRadius="14" Padding="10,5"><TextBlock Text="重新生成" Foreground="#3B82F6" FontSize="11"/></Border>
                <Border Background="#1A3FB950" CornerRadius="14" Padding="10,5"><TextBlock Text="存为方案" Foreground="#3FB950" FontSize="11"/></Border>
            </StackPanel>
            <!-- AI 输入（可真实输入） -->
            <Border Grid.Row="3" Background="#16182A" CornerRadius="8" Margin="12,0,12,12" Padding="4,2">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBox Grid.Column="0" PlaceholderText="输入指令…" Background="Transparent" BorderThickness="0"
                             Foreground="#C9D1D9" FontSize="13" VerticalAlignment="Center" Padding="8,7" CaretBrush="#FF4B6E"/>
                    <Button Grid.Column="1" Background="#FF4B6E" CornerRadius="14" Width="28" Height="28" Padding="0"
                            VerticalAlignment="Center" Margin="4,0">
                        <TextBlock Text="↑" Foreground="#FFFFFF" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
